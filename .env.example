# Copie este arquivo para .env e preencha (ou informe direto na UI).

# Last.fm — crie uma API key em https://www.last.fm/api/account/create
VITE_LASTFM_API_KEY=

# Spotify — crie um app em https://developer.spotify.com/dashboard e cadastre
# a Redirect URI (a URL onde o site roda, ex.: http://localhost:5173/).
# Só o Client ID é necessário (o fluxo é PKCE, sem client secret).
VITE_SPOTIFY_CLIENT_ID=
